{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Quota kolla",
  "version": "0.1.0",
  "identifier": "com.tonnguyen.quota-kolla",
  "build": {
    "beforeDevCommand": "node ../scripts/build-frontend.mjs",
    "beforeBuildCommand": "node ../scripts/build-frontend.mjs",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "menu",
        "url": "menu.html",
        "visible": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "transparent": true,
        "backgroundColor": "#00000000"
      },
      {
        "label": "preferences",
        "url": "preferences.html",
        "visible": false,
        "decorations": true,
        "resizable": false,
        "width": 400,
        "height": 350
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
