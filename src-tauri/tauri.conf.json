{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MenuBar Progress",
  "version": "0.1.0",
  "identifier": "com.example.menubar-progress",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "menu",
        "url": "menu.html",
        "visible": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true
      },
      {
        "label": "preferences",
        "url": "preferences.html",
        "visible": false,
        "decorations": true,
        "resizable": false,
        "width": 400,
        "height": 350
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  },
  "plugins": {}
}
